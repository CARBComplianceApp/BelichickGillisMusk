# Gemini (frontend + API)
GEMINI_API_KEY=

# --- Cloudflare Pages (norcalcarbmobile.com) ---
# Cursor Cloud Agent secret name: CF DEPLOY
# Cloudflare Account API token with Pages → Edit permission.
# CF DEPLOY=cfat_...

# --- Gmail API (backend /api routes) ---
# Option A (preferred): Service account JSON as a single-line string OR path to .json file
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Required when using a service account (Workspace domain-wide delegation):
# GOOGLE_IMPERSONATE_USER=bryan@norcalcarbmobile.com

# Option B: OAuth refresh token (personal Gmail)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REFRESH_TOKEN=your-refresh-token
# GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Optional default From header for outbound mail
# GMAIL_FROM="GIA <bryan@norcalcarbmobile.com>"
